# Copy to .env and fill in. .env is gitignored and never committed.

# Which provider the router uses by default: openai | anthropic
DEFAULT_PROVIDER=anthropic

# Provider credentials (set the one(s) you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6
